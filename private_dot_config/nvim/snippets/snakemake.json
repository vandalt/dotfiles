{
  "output rule": {
    "prefix": "orule",
    "body": ["rule ${1:name}:", "\toutput:", "\t\t${2:output}", "\tscript:", "\t\t${3:script}"],
    "description": "snakemake rule with an output only"
  },
  "input rule": {
    "prefix": "irule",
    "body": ["rule ${1:name}:", "\tinput:", "\t\t${2:input}", "\tscript:", "\t\t${3:script}"],
    "description": "snakemake rule with an output only"
  },
  "rule": {
    "prefix": "srule",
    "body": ["rule ${1:name}:", "\tinput:", "\t\t${2:input}", "\toutput:", "\t\t${3:output}", "\tscript:", "\t\t${4:script}"],
    "description": "snakemake rule"
  }
}
